# ── Required ──────────────────────────────────────────────────────────────────

# Bot token from the Discord Developer Portal (Bot → Token)
BOT_TOKEN=

# Application ID from the Discord Developer Portal (General Information → Application ID)
CLIENT_ID=

# ── Optional ──────────────────────────────────────────────────────────────────

# Guild ID for dev — commands deployed here are instant instead of taking up to 1h globally.
# Leave empty for production (global deployment).
DEV_GUILD_ID=

# Path to the SQLite database file. Created automatically on first run.
DATABASE_PATH=./data/meisbot.db

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
